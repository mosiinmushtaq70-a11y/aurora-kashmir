# Environment Variables Template
# Copy this to .env for local development

# -----------------
# CLIENT-SIDE (Browser)
# These MUST start with NEXT_PUBLIC_
# -----------------
NEXT_PUBLIC_MAPTILER_KEY="your_maptiler_key_here"
NEXT_PUBLIC_BACKEND_URL="http://localhost:8000" # Use Render URL for production
NEXT_PUBLIC_SUPABASE_URL="https://your_project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="your_supabase_key_here"

# -----------------
# SERVER-SIDE (Secrets)
# These are NOT exposed to the browser
# -----------------
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"
NVIDIA_API_KEY="your_nvidia_key_here"
NASA_API_KEY="your_nasa_key_here" # Used by backend/Python only
